# Anthropic — used for Claude ranking when provider=claude
ANTHROPIC_API_KEY=sk-ant-...

# Auth — sign JWTs with this secret; create per-user tokens containing { email }
JWT_SECRET=replace-with-a-long-random-secret

# Server
PORT=3000
